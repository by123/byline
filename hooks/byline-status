#!/bin/sh
# byline-status — publish the current agent session's state for Byline's sidebar.
#
#   Usage: byline-status {start|think|confirm|done|off}
#
# Writes the state word to /tmp/byline_sessions/$BYLINE_SID (atomic tmp+rename).
# BYLINE_SID is set by Byline per terminal tab; outside Byline this is a no-op,
# so the same hook config is safe in any terminal. Never exits non-zero and
# never prints: a status hook must not be able to break the agent that calls it.

[ -n "$BYLINE_SID" ] || exit 0
case "$BYLINE_SID" in *[!0-9A-Za-z-]*) exit 0 ;; esac    # sid is also a filename: allow [0-9A-Za-z-] only
case "$1" in start|think|confirm|done|off) ;; *) exit 0 ;; esac

DIR=/tmp/byline_sessions
mkdir -p "$DIR" 2>/dev/null || exit 0
printf '%s' "$1" > "$DIR/$BYLINE_SID.tmp" 2>/dev/null || exit 0
mv -f "$DIR/$BYLINE_SID.tmp" "$DIR/$BYLINE_SID" 2>/dev/null

# Record which agent session THIS tab is driving, so a handoff hands over this tab's session
# rather than merely the newest session in the project dir (two tabs in one cwd would otherwise
# collide). Claude Code and Codex both pass a JSON payload on stdin carrying the live session's
# id and transcript file (for codex, the rollout file); capture them and publish a per-tab map
# at <sid>.session. Reading all of stdin also drains the payload (never leave the agent's write
# end with a broken pipe). Register this same hook in ~/.codex/hooks.json to cover codex too.
if [ ! -t 0 ]; then
  payload=$(cat 2>/dev/null)
  sid=$(printf '%s' "$payload" | sed -n 's/.*"session_id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n 1)
  tpath=$(printf '%s' "$payload" | sed -n 's/.*"transcript_path"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n 1)
  # need the transcript file to archive; never clobber a good map with a pathless event
  if [ -n "$tpath" ]; then
    printf '%s\n%s\n' "$sid" "$tpath" > "$DIR/$BYLINE_SID.session.tmp" 2>/dev/null \
      && mv -f "$DIR/$BYLINE_SID.session.tmp" "$DIR/$BYLINE_SID.session" 2>/dev/null
  fi
fi
exit 0
